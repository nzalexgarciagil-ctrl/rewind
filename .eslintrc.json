{
  "env": {
    "browser": true,
    "node": false
  },
  "globals": {
    "cep_node": "readonly",
    "CSInterface": "readonly",
    "Bridge": "readonly",
    "GitManager": "readonly",
    "GitHubManager": "readonly",
    "VersionController": "readonly",
    "PrprojHandler": "readonly",
    "DiffEngine": "readonly",
    "DebugConsole": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 5
  },
  "rules": {
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "eqeqeq": ["error", "always"],
    "no-var": "off",
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-undef": "error",
    "no-redeclare": "error",
    "no-shadow": "warn",
    "curly": ["warn", "multi-line"],
    "semi": ["warn", "always"]
  }
}
