<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Version="11.0" ExtensionBundleId="com.example.rewind-demo" ExtensionBundleName="Rewind Demo" ExtensionBundleVersion="1.0.0">
    <ExtensionList>
        <Extension Id="com.example.rewind-demo.panel" Version="1.0.0"/>
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="[22.0,99.9]"/>
        </HostList>
        <LocaleList><Locale Code="All"/></LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.example.rewind-demo.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./rewind-sdk/host/rewind-host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Rewind Demo</Menu>
                    <Geometry>
                        <Size><Height>500</Height><Width>300</Width></Size>
                        <MinSize><Height>300</Height><Width>250</Width></MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
